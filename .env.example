# --- Database (libSQL / Turso) ---
# Leave both unset for local development: the app falls back to a file-backed
# libSQL database at ./data/banha.db.
#
# Set these in production (e.g. Vercel project env vars) to point at Turso:
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- OpenAI (bill-photo extraction) ---
OPENAI_API_KEY=
# Optional model override (default: gpt-5-mini). Reasoning effort default: low.
# OPENAI_MODEL=gpt-5-mini
# OPENAI_REASONING_EFFORT=low

# --- Auth tokens (optional; sensible defaults exist in code) ---
# ADMIN_TOKEN=
# USER_TOKEN=

# --- Telegram (set in production) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ADMIN_USERNAMES=comma,separated,usernames
# TELEGRAM_USER_USERNAMES=comma,separated,usernames
